            </connector>
            <label>Field Values Available</label>
        </rules>
    </decisions>
    <decisions>
        <name>Check_Term_Duration</name>
        <label>Check Term Duration</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Check_Account_is_LP_CP</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Year</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Term_Duration__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>YEAR</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign</targetReference>
            </connector>
            <label>Year</label>
        </rules>
        <rules>
            <name>Month</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Term_Duration__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>MONTH</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Monthly_Fee</targetReference>
            </connector>
            <label>Month</label>
        </rules>
        <rules>
            <name>Week</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Term_Duration__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>WEEK</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Weekly_Fee</targetReference>
            </connector>
            <label>Week</label>
        </rules>
        <rules>
            <name>Day</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Term_Duration__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>DAY</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Daily_Fee</targetReference>
            </connector>
            <label>Day</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>DailyFee</name>
        <dataType>Currency</dataType>
        <expression>({!$Record.Membership_Type__r.Price__c}/365)*{!$Record.Term_Length__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>MonthlyFee</name>
        <dataType>Currency</dataType>
        <expression>({!$Record.Membership_Type__r.Price__c}/12)*{!$Record.Term_Length__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>WeeklyFee</name>
        <dataType>Currency</dataType>
        <expression>({!$Record.Membership_Type__r.Price__c}/52)*{!$Record.Term_Length__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>YearlyFee</name>
        <dataType>Currency</dataType>
        <expression>{!$Record.Membership_Type__r.Price__c}*{!$Record.Term_Length__c}</expression>
        <scale>2</scale>
    </formulas>
