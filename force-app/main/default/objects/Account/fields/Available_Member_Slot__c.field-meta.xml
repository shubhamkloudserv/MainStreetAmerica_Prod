<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Available_Member_Slot__c</fullName>
    <description>Stores available member slots; used when adding new members.</description>
    <externalId>false</externalId>
    <formula>MAX(0, Max_Sub_Members__c  -  Rollup_Sub_Member__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Available Member Slot</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
