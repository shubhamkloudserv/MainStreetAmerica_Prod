<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Legal_Entity_Name__c</fullName>
    <description>Stores legal entity name; used in invoices and contracts</description>
    <externalId>false</externalId>
    <formula>IF(
  LEN(Name) &gt; 25,
  LEFT(Name, 25),
  Name
)</formula>
    <label>Legal Entity Name (25 characters)</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
