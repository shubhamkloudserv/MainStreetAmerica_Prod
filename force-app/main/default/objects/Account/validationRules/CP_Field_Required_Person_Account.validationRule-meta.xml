<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CP_Field_Required_Person_Account</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
IsPersonAccount,
Paid_By_CP__c = TRUE,
ISBLANK(Parent_Account__c)
)</errorConditionFormula>
    <errorDisplayField>Parent_Account__c</errorDisplayField>
    <errorMessage>Coordinating Program must be filled in when Paid By CP is checked.</errorMessage>
</ValidationRule>
