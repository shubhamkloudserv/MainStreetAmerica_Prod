<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Payment_Method_Required_for_Paid_Status</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
  ISPICKVAL( Status__c, &apos;Paid&apos;),
  ISPICKVAL( PaymentMethod__c, &quot;&quot;)
)</errorConditionFormula>
    <errorMessage>Please provide a payment method when the status is &apos;Paid&apos;.</errorMessage>
</ValidationRule>
