<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Order_End_Date_Mandatory</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISPICKVAL(Account.Program_Type__c, &quot;Coordinating Program&quot;),
  ISBLANK(EndDate)
)</errorConditionFormula>
    <errorDisplayField>EndDate</errorDisplayField>
    <errorMessage>Please fill the order end date.</errorMessage>
</ValidationRule>
